# TungZone backend optional environment variables.
# Local defaults already work without this file.
# Only use these when your machine differs from the defaults.

# Database
DB_URL=jdbc:mysql://127.0.0.1:3306/tung_zone?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Ho_Chi_Minh
DB_USERNAME=root
DB_PASSWORD=

# App
PORT=8085
JWT_EXPIRATION=86400000
# JWT_SECRET must be at least 32 characters if overridden.
# JWT_SECRET=your-256-bit-secret-key-minimum-32-chars

# Google OAuth Client ID (optional, for Google login)
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Optional admin seed. Leave empty unless you intentionally want to create/rotate an admin.
# SEED_ADMIN_EMAIL=owner@example.com
# SEED_ADMIN_PASSWORD=change-me-with-a-strong-password
# SEED_ADMIN_FULL_NAME=Store Owner

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*,https://*.vercel.app

# MoMo Payment (optional)
# MOMO_PARTNER_CODE=your-partner-code
# MOMO_ACCESS_KEY=your-access-key
# MOMO_SECRET_KEY=your-secret-key
# MOMO_IPN_URL=https://your-domain.com/api/payments/momo/ipn
# MOMO_REDIRECT_URL=https://your-domain.com/cart

# File upload directory
# APP_UPLOAD_DIR=uploads

# Email SMTP (required only for real forgot-password email)
MAIL_ENABLED=true
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
FRONTEND_RESET_PASSWORD_URL=http://localhost:5173/login
FRONTEND_ORDERS_URL=http://localhost:5173/profile?tab=orders
